  "keyFeatures": [
    "Personalized event discovery with career-aware scoring",
    "Intelligent event recommendations based on skills and goals",
    "Calendar integration and event scheduling",
    "Career dashboard with analytics and goal tracking",
    "Hackathon team coordination and participation",
    "Community profiles and social networking",
    "Automated event ingestion from multiple sources",
    "Behavioral analytics and recommendation tuning"
  ],
  "publicApiSurface": [
    "POST /api/events/filtered - Retrieve filtered events with career scoring",
    "GET /api/events/recommendations - Get personalized event recommendations",
    "Client-side tracking via Supabase RPC - Track user event bookmarks and attendance",
    "GET /api/dashboard/analytics - Fetch career analytics and insights",
    "POST /api/calendar/sync - Sync events with external calendars",
    "GET /api/calendar/google/connect - Connect Google Calendar",
    "GET /api/calendar/google/status - Check calendar connection status",
    "GET /api/profile - Retrieve user profile",
    "PATCH /api/profile - Update user profile",
    "GET /api/profile/social - Get social profile settings",
    "POST /api/admin/ingestion/run - Trigger event ingestion pipeline",
    "GET /api/users/search - Search users and profiles",
    "GET /api/follows/[userId] - Get follow relationship",
    "POST /api/follows - Follow a user",
    "DELETE /api/follows/[userId] - Unfollow a user",
    "GET /api/blocks - Get blocked users",
    "POST /api/blocks - Block a user"
  ]
