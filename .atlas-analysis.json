  "keyFeatures": [
    "Personalized event discovery with career-aware scoring",
    "Intelligent event recommendations based on skills and goals",
    "Calendar integration and event scheduling",
    "Career dashboard with analytics and goal tracking",
    "Hackathon team coordination and participation",
    "Community profiles and social networking",
    "Automated event ingestion from multiple sources",
    "Behavioral analytics and recommendation tuning"
  ],
  "publicApiSurface": [
    "GET /api/events/filtered - Retrieve filtered events with career scoring",
    "GET /api/events/recommendations - Get personalized event recommendations",
    "POST /api/events/tracked - Track user event interactions",
    "GET /api/dashboard/analytics - Fetch career analytics and insights",
    "POST /api/calendar/sync - Sync events with external calendars",
    "GET /api/profile/career - Retrieve user career profile",
    "PUT /api/profile/career - Update career profile and preferences",
    "POST /api/admin/ingestion/run - Trigger event ingestion pipeline",
    "GET /api/community/search - Search users and profiles",
    "POST /api/hackathons/teams - Create or join hackathon teams"
